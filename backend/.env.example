# -------------------------------------------------------
# DosePair Backend v1 - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# -------------------------------------------------------

# Active LLM provider.
# Valid values: anthropic | openai | grok | gemini | deepseek | qwen
LLM_PROVIDER=anthropic

# Server port (default: 3001)
PORT=3001

# Comma-separated list of allowed CORS origins.
# Use * to allow all origins (development only).
ALLOWED_ORIGINS=http://localhost:3000

# -------------------------------------------------------
# Provider API keys - only populate the one you use
# -------------------------------------------------------

# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (ChatGPT) - https://platform.openai.com
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# xAI Grok (OpenAI-compatible) - https://console.x.ai
GROK_API_KEY=xai-...
GROK_BASE_URL=https://api.x.ai/v1
# GROK_MODEL=grok-3

# Google Gemini - https://aistudio.google.com
GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash

# DeepSeek (OpenAI-compatible) - https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# Qwen (OpenAI-compatible) - https://dashscope.console.aliyun.com
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

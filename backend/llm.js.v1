'use strict';

/**
 * Multi-provider LLM adapter for DosePair backend v1.
 *
 * Supported providers (set LLM_PROVIDER in .env):
 *   anthropic  - Claude via Anthropic SDK
 *   openai     - ChatGPT via OpenAI SDK
 *   grok       - xAI Grok (OpenAI-compatible API)
 *   gemini     - Google Gemini via @google/generative-ai
 *   deepseek   - DeepSeek (OpenAI-compatible API)
 *   qwen       - Alibaba Qwen (OpenAI-compatible API)
 *
 * All adapters expose a single method:
 *   complete(systemPrompt: string, userMessage: string): Promise<string>
 *
 * Model and base URL overrides are available via env vars for each provider.
 * See .env.example for the full list.
 */

const PROVIDER_DEFAULTS = {
  anthropic: {
    model: 'claude-sonnet-4-6',
    maxTokens: 4096,
  },
  openai: {
    model: 'gpt-4o',
    maxTokens: 4096,
    baseURL: null,
  },
  grok: {
    model: 'grok-3',
    maxTokens: 4096,
    baseURL: 'https://api.x.ai/v1',
  },
  gemini: {
    model: 'gemini-2.5-flash',
    maxTokens: 4096,
  },
  deepseek: {
    model: 'deepseek-chat',
    maxTokens: 4096,
    baseURL: 'https://api.deepseek.com/v1',
  },
  qwen: {
    model: 'qwen-plus',
    maxTokens: 4096,
    baseURL: 'https://dashscope.aliyuncs.com/compatible-mode/v1',
  },
};

function resolveConfig(provider) {
  const defaults = PROVIDER_DEFAULTS[provider];
  if (!defaults) return null;

  const upper = provider.toUpperCase();
  return {
    model: process.env[`${upper}_MODEL`] || defaults.model,
    maxTokens: defaults.maxTokens,
    baseURL: process.env[`${upper}_BASE_URL`] || defaults.baseURL || null,
  };
}

// Anthropic adapter using the official SDK
function createAnthropicAdapter(config) {
  const { Anthropic } = require('@anthropic-ai/sdk');
  const key = process.env.ANTHROPIC_API_KEY;
  if (!key) throw new Error('ANTHROPIC_API_KEY is not set.');
  const client = new Anthropic({ apiKey: key });

  return {
    provider: 'anthropic',
    model: config.model,
    async complete(systemPrompt, userMessage) {
      const response = await client.messages.create({
        model: config.model,
        max_tokens: config.maxTokens,
        system: systemPrompt,
        messages: [{ role: 'user', content: userMessage }],
      });
      const block = response.content.find((b) => b.type === 'text');
      if (!block) throw new Error('Anthropic returned no text content.');
      return block.text;
    },
  };
}

// Generic OpenAI-compatible adapter (covers OpenAI, Grok, DeepSeek, Qwen)
function createOpenAICompatibleAdapter(provider, config, apiKey) {
  const { OpenAI } = require('openai');
  const clientOptions = { apiKey };
  if (config.baseURL) clientOptions.baseURL = config.baseURL;
  const client = new OpenAI(clientOptions);

  return {
    provider,
    model: config.model,
    async complete(systemPrompt, userMessage) {
      const response = await client.chat.completions.create({
        model: config.model,
        max_tokens: config.maxTokens,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: userMessage },
        ],
      });
      const choice = response.choices[0];
      if (!choice || !choice.message?.content) {
        throw new Error(`${provider} returned no message content.`);
      }
      return choice.message.content;
    },
  };
}

// Google Gemini adapter
function createGeminiAdapter(config) {
  const { GoogleGenerativeAI } = require('@google/generative-ai');
  const key = process.env.GEMINI_API_KEY;
  if (!key) throw new Error('GEMINI_API_KEY is not set.');
  const genAI = new GoogleGenerativeAI(key);

  return {
    provider: 'gemini',
    model: config.model,
    async complete(systemPrompt, userMessage) {
      const model = genAI.getGenerativeModel({
        model: config.model,
        systemInstruction: systemPrompt,
        generationConfig: { maxOutputTokens: config.maxTokens },
      });
      const result = await model.generateContent(userMessage);
      const text = result.response.text();
      if (!text) throw new Error('Gemini returned no text content.');
      return text;
    },
  };
}

function createLLMAdapter() {
  const provider = (process.env.LLM_PROVIDER || 'anthropic').toLowerCase().trim();
  const config = resolveConfig(provider);

  if (!config) {
    const valid = Object.keys(PROVIDER_DEFAULTS).join(', ');
    throw new Error(
      `Unknown LLM_PROVIDER "${provider}". Valid options: ${valid}.`
    );
  }

  switch (provider) {
    case 'anthropic':
      return createAnthropicAdapter(config);

    case 'openai': {
      const key = process.env.OPENAI_API_KEY;
      if (!key) throw new Error('OPENAI_API_KEY is not set.');
      return createOpenAICompatibleAdapter('openai', config, key);
    }

    case 'grok': {
      const key = process.env.GROK_API_KEY;
      if (!key) throw new Error('GROK_API_KEY is not set.');
      return createOpenAICompatibleAdapter('grok', config, key);
    }

    case 'deepseek': {
      const key = process.env.DEEPSEEK_API_KEY;
      if (!key) throw new Error('DEEPSEEK_API_KEY is not set.');
      return createOpenAICompatibleAdapter('deepseek', config, key);
    }

    case 'qwen': {
      const key = process.env.QWEN_API_KEY;
      if (!key) throw new Error('QWEN_API_KEY is not set.');
      return createOpenAICompatibleAdapter('qwen', config, key);
    }

    case 'gemini':
      return createGeminiAdapter(config);

    default:
      throw new Error(`No adapter implemented for provider "${provider}".`);
  }
}

module.exports = { createLLMAdapter };

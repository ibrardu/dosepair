'use strict';

require('dotenv').config();

const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const rateLimit = require('express-rate-limit');

const { validateMedications } = require('./validate.js.v1');

const app = express();
const PORT = process.env.PORT || 3001;

// Security headers via helmet
app.use(helmet());

// CORS - restrict to configured origins in production
const allowedOrigins = process.env.ALLOWED_ORIGINS
  ? process.env.ALLOWED_ORIGINS.split(',').map((o) => o.trim())
  : '*';

app.use(
  cors({
    origin: allowedOrigins,
    methods: ['GET', 'POST'],
    allowedHeaders: ['Content-Type'],
  })
);

// JSON body parsing with explicit error handling for malformed payloads
app.use((req, res, next) => {
  express.json({ limit: '10kb' })(req, res, (err) => {
    if (err) {
      return res.status(400).json({ error: 'Invalid JSON in request body.' });
    }
    next();
  });
});

// Rate limiter: 10 requests per minute per IP
const analyzeLimiter = rateLimit({
  windowMs: 60 * 1000,
  max: 10,
  standardHeaders: true,
  legacyHeaders: false,
  keyGenerator: (req) => req.ip,
  handler: (req, res) => {
    res.status(429).json({
      error: 'Too many requests. Limit is 10 per minute per IP. Please wait and retry.',
    });
  },
});

// Health check - reveals active provider, never reveals keys
app.get('/health', (req, res) => {
  res.json({
    status: 'ok',
    provider: process.env.LLM_PROVIDER || 'anthropic',
    version: 'v1',
  });
});

// POST /api/analyze - placeholder wired with rate limiter and validation
// Full implementation added in chunk 4 once LLM adapters are in place
app.post('/api/analyze', analyzeLimiter, (req, res) => {
  const error = validateMedications(req.body);
  if (error) {
    return res.status(400).json({ error });
  }
  res.status(501).json({ error: 'LLM adapter not yet wired. Coming in chunk 4.' });
});

// 404 handler for any unmatched route
app.use((req, res) => {
  res.status(404).json({ error: 'Not found.' });
});

// Global error handler - never leak stack traces to clients
app.use((err, req, res, _next) => {
  console.error('[dosepair] Unhandled error:', err.message);
  res.status(500).json({ error: 'Internal server error.' });
});

if (require.main === module) {
  app.listen(PORT, () => {
    console.log(
      `[dosepair] Backend v1 running on port ${PORT} (provider: ${process.env.LLM_PROVIDER || 'anthropic'})`
    );
  });
}

module.exports = app;
